# Wadiz Data Pipeline Demo Environment
# 이 파일은 공개 저장소에 올릴 수 있는 예시입니다.
# 실제 값은 .env에만 저장하고 Git에는 올리지 않습니다.

# 실행 모드
DEMO_MODE=true

# AWS 기본값
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=000000000000

# S3 / Athena
S3_BUCKET=your-data-lake-bucket
BRONZE_PREFIX=bronze/wadiz
SILVER_PREFIX=silver2/wadiz
SILVER_ERROR_PREFIX=silver_error/wadiz
GOLD_PREFIX=gold2/wadiz
ATHENA_QUERY_RESULT_BUCKET=your-athena-query-result-bucket
ATHENA_QUERY_RESULT_PREFIX=athena-results/
ATHENA_WORKGROUP=primary

# Athena DB
BRONZE_DB=wadiz_bronze_db
SILVER_DB=wadiz_silver2_db
GOLD_DB=wadiz_gold2_db

# ECS
ECS_CLUSTER=ecs-cluster
ECS_SUBNETS=subnet-xxxxxxxx,subnet-yyyyyyyy
ECS_SECURITY_GROUPS=sg-xxxxxxxx
ECS_ASSIGN_PUBLIC_IP=ENABLED
ECS_PLATFORM_VERSION=1.4.0

ECS_TASK_FAMILY_BRONZE=wd-bronze-crawler
ECS_TASK_FAMILY_SILVER=wd-silver-etl
ECS_TASK_FAMILY_DASHBOARD_EXPORT=wd-dashboard-export
ECS_CONTAINER_BRONZE=wd-bronze-container
ECS_CONTAINER_SILVER=wd-silver-container
ECS_CONTAINER_DASHBOARD_EXPORT=wd-dashboard-export-container

ECS_TASK_EXECUTION_ROLE_ARN=arn:aws:iam::000000000000:role/your-ecs-execution-role
ECS_TASK_ROLE_ARN=arn:aws:iam::000000000000:role/your-ecs-task-role

ECR_IMAGE_BRONZE=000000000000.dkr.ecr.ap-northeast-2.amazonaws.com/wd-crawler:latest
ECR_IMAGE_SILVER=000000000000.dkr.ecr.ap-northeast-2.amazonaws.com/wd-crawler:latest
ECR_IMAGE_DASHBOARD_EXPORT=000000000000.dkr.ecr.ap-northeast-2.amazonaws.com/wd-crawler:latest

# 원천 API 도메인
# 공개 저장소에는 실제 도메인을 쓰지 않습니다.
# 실제 실행 시에만 개인 .env에서 입력합니다.
SOURCE_BASE_URL=https://example.invalid
SOURCE_PREORDER_SEARCH_URL=https://example.invalid/api/search/v2/preorder

# Bronze crawler option
BRONZE_REQUEST_TIMEOUT=20
BRONZE_PAGE_SLEEP_SEC=0.25
BRONZE_MAX_PAGES=0
BRONZE_MAX_RECORDS=0
BRONZE_CAMPAIGN_IDS=
BRONZE_USER_IDS=

# Silver
SILVER_HASH_SALT=replace-this-with-a-private-random-string
SILVER_WRITE_ERROR_ROWS=true
SILVER_ALLOW_EMPTY=false

# Tableau / Google Sheets export
GOOGLE_APPLICATION_CREDENTIALS=secrets/google_service_account.json
GOOGLE_SHEETS_SPREADSHEET_ID=replace-with-spreadsheet-id
WADIZ_GOLD_SQL_DIR=wd_gold/sql
