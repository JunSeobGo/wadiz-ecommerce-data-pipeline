FROM python:3.11-slim
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
WORKDIR /app
COPY requirements-silver.txt /app/requirements-silver.txt
RUN pip install --no-cache-dir -r /app/requirements-silver.txt
COPY wd_silver /app/wd_silver
COPY wd_bronze /app/wd_bronze
COPY wd_dashboard_export /app/wd_dashboard_export
CMD ["python", "-m", "wd_silver.run_silver", "--table", "preorder", "--dt", "20260505", "--dry-run"]
